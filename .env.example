# Encryption key for storing credentials at rest (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=your-fernet-key-here

# Database
DATABASE_URL=sqlite:///data/omakase.db

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Omakase.in credentials (optional - can also be set via UI)
OMAKASE_EMAIL=
OMAKASE_PASSWORD=

# Playwright
PLAYWRIGHT_BROWSERS_PATH=/app/browsers
HEADLESS=true
